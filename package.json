{
  "name": "my-memos",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @my-memos/app dev",
    "dev:wrangler": "pnpm build && wrangler dev --remote",
    "dev:storybook": "pnpm --filter @my-memos/ui dev",
    "build": "pnpm --filter @my-memos/app build",
    "drizzle:generate": "drizzle-kit generate",
    "d1:migrate:local": "wrangler d1 migrations apply DB --local --persist-to .wrangler --config wrangler.toml",
    "d1:migrate:remote": "wrangler d1 migrations apply DB --remote --config wrangler.toml",
    "check": "vp check && svelte-check --workspace packages/ui --tsconfig tsconfig.json && svelte-check --workspace apps/memos --tsconfig tsconfig.check.json && tsgo --noEmit",
    "lint": "vp lint",
    "format": "vp fmt"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.2",
    "@cloudflare/workers-types": "4.20260520.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "25.9.1",
    "@typescript/native-preview": "beta",
    "drizzle-kit": "1.0.0-rc.2",
    "svelte": "5.55.8",
    "svelte-check": "4.4.8",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite-plus": "0.1.22",
    "wrangler": "4.93.0"
  },
  "packageManager": "pnpm@11.1.3"
}
